# 复制成 .env 再填。.env 不会进 git（见 .gitignore）。
# 门B：EvoMap 开发者 API（搜 recipe）。token 用 OAuth2+PKCE 拿（公共只读 client），1h 过期，带 refresh 自动续期。
EVOMAP_TOKEN=
EVOMAP_REFRESH_TOKEN=
EVOMAP_CLIENT_ID=
# 门C：EvoMap 模型网关（流式写代码），OpenAI 兼容
MODEL_BASE_URL=https://api.evomap.ai/v1
MODEL_NAME=evomap-deepseek-v4-flash
MODEL_KEY=                # sk-evomap-...
