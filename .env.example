# 复制成 .env 再填。.env 不会进 git（见 .gitignore）。
# 经验检索（门B：EvoMap 开发者 API，OAuth2 access token，scope recipe:read gene:read）
EVOMAP_TOKEN=
# 模型后端（门C：EvoMap 自己的 LLM 网关，OpenAI 兼容）
MODEL_BASE_URL=https://api.evomap.ai/v1
MODEL_NAME=evomap-deepseek-v4-flash
MODEL_KEY=                # sk-evomap-... 你的 EvoMap 模型 key
# 也可把 MODEL_BASE_URL/MODEL_NAME/MODEL_KEY 指到任意 OpenAI 兼容端点（如自带的别家模型）
